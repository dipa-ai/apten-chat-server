# Server
SERVER_PORT=8080

# Database
DATABASE_URL=postgres://messenger:messenger@localhost:5432/messenger?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# S3
S3_BUCKET=messenger-files
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
FILE_MAX_SIZE=52428800

# VAPID (Web Push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@example.com

# Invites
INVITE_TTL=168h

# WebSocket: comma-separated Origin allowlist. Leave empty to allow any origin
# (local dev). The Vite dev server runs on :3000.
WS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
